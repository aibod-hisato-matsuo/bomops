%% L4 BAITENサービス管理 — Relational ER図
%% Notion DB群をリレーショナルDBに正規化したER図
erDiagram
    AIBOD_Entity ||--o{ Service_Management : "設置主体"
    Service_Management ||--o{ Product_Set : "1拠点に複数台"
    Product_Set ||--o{ Parts : "完成品=部品の集合"
    BOM ||--o{ Parts : "仕様(型番)→実機"
    Equipment_Mgmt }o--o{ Parts : "機器⇔部品(N:M)"

    AIBOD_Entity {
        string EntityNum PK "外部マスタ(c3bde0b2)"
        string name
    }

    Service_Management {
        string Location PK "設置場所/店舗(title)"
        string Loyverse_Account
        string Loyverse_StoreID
        string Loyverse_Token
        string SQUARE_Account
        string SQU_DEVICE_ID
        string SQU_LOCATION_ID
        string SQU_TOKEN
        string PAYPAY_SECRET
        string BAITEN_CLOUD_KEY
        string GOOGLE_SECRET
        string SLACK_BOT_TOKEN
        text   config_toml
        text   baiten_env
        select 稼働 "準備中/稼働中/撤退済/拠点/貸出中"
        multi  CAM_ARM_DARM_DIS_ENC_etc "HWスロット割当(多値)"
        string AIBOD_Entity_FK FK
    }

    Product_Set {
        string Set PK "完成品セット名(title)"
        select Model "BAITEN AI/Mini/stock/出張中/転用中"
        date   出荷日
        string Service_Management_FK FK
    }

    Parts {
        string Part PK "部品名(title)"
        string S_N "シリアル番号"
        select 不良 "不良/OK"
        select 実用化対象 "R4/R5/NA..."
        date   確認日
        date   購入日
        string Product_Set_FK FK
        string BOM_FK FK
    }

    BOM {
        string Item PK "部品仕様/型番(title)"
        select Category "本体構成品/オプション品/組立部品..."
        select Type "MiniPC/PayDevice/カメラ/モニター..."
        text   Provider
        text   仕様
        text   サイズ
        bool   AI使用
        bool   Mini使用
    }

    Equipment_Mgmt {
        string id PK "L4 機器管理DB(183e91a9・外部)"
    }

    %% --- リレーションを持たない独立DB（参照用・正規化対象外） ---
    SQUARE_Service {
        string Name PK "L5 BAITEN SQUARE DB(POS/決済)"
        string S_N
        date   購入日
        select 実用化対象
    }

    Parts_Spec_Notes {
        string Name PK "L5 BAITEN 部品仕様DB(メモ)"
    }
